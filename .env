# VLM endpoint (DeepSeek-OCR-2 or any OpenAI-compatible vision model)
VLM_ENDPOINT=http://localhost:8000/v1/chat/completions
VLM_MODEL=deepseek-ocr-2
VLM_API_KEY=
VLM_TIMEOUT_S=60
VLM_MAX_RETRIES=3
VLM_CONCURRENCY_LIMIT=8
VLM_CORRECTION_MAX_PASSES=2

# Text embedding endpoint
EMBED_ENDPOINT=http://localhost:8001/v1/embeddings
EMBED_MODEL=BAAI/bge-m3
EMBED_API_KEY=
EMBED_DIMENSIONS=1024

# Visual embedding endpoint (optional — ColPali/ColQwen2)
VISUAL_EMBED_ENABLED=false
VISUAL_EMBED_ENDPOINT=
VISUAL_EMBED_MODEL=
VISUAL_EMBED_API_KEY=
VISUAL_EMBED_DIMENSIONS=128

# MongoDB
DB_MONGODB_URI=mongodb://mongo:27017/docintel

# PostgreSQL
DB_POSTGRES_DSN=postgresql://docintel:docintel@postgres:5432/docintel

# Neo4j
DB_NEO4J_URI=bolt://neo4j:7687
DB_NEO4J_USER=neo4j
DB_NEO4J_PASSWORD=docintel_neo4j

# Vector database backend: pgvector or qdrant
DB_VECTOR_BACKEND=pgvector
DB_QDRANT_HOST=qdrant
DB_QDRANT_PORT=6333
DB_QDRANT_COLLECTION=docintel_chunks

# Image storage
DB_IMAGE_STORE_PATH=/data/images
DB_IMAGE_BASE_URL=

# Celery / Redis
QUEUE_BROKER_URL=redis://redis:6379/0
QUEUE_RESULT_BACKEND=redis://redis:6379/1
QUEUE_TASK_TIME_LIMIT=600

# Observability
OBS_PROMETHEUS_PORT=9090
OBS_OTEL_ENDPOINT=
OBS_LOG_LEVEL=INFO
OBS_SERVICE_NAME=docintel

# Layout detector
LAYOUT_MODEL_PATH=configs/doclayout_yolo.pt
LAYOUT_CONF_THRESHOLD=0.25
LAYOUT_IOU_THRESHOLD=0.45
LAYOUT_DEVICE=cpu
LAYOUT_INPUT_SIZE=1024
